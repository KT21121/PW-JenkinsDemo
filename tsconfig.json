{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "esModuleInterop": true,            // 👈 Esto permite importar dotenv sin errores
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["tests/**/*", "pages/**/*", "config/**/*", "playwright.config.ts"]
}